{% comment %}
  “pages” template. Named after a content type (events, people…), this
  renders that type’s pages instead of templates/default.liquid. Context available:
  page (this object’s fields), content (its rendered body), site, seo, collections.
{% endcomment %}

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ seo.title }}</title>
    <meta name="description" content="{{ seo.description }}" />
    <link rel="canonical" href="{{ seo.canonical }}" />
    <meta property="og:title" content="{{ seo.ogTitle }}" />
    <meta property="og:description" content="{{ seo.ogDescription }}" />
    <meta property="og:type" content="{{ seo.ogType }}" />
    {% if seo.ogImage %}<meta property="og:image" content="{{ seo.ogImage }}" />{% endif %}
    <link rel="stylesheet" href="{{ site.basePath }}/assets/theme.css" />
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href="{{ site.basePath }}/">{{ site.title }}</a>
      <nav class="site-nav">
        {% for item in site.nav %}<a href="{{ site.basePath }}{{ item.url }}">{{ item.label }}</a>{% endfor %}
      </nav>
    </header>
    <main class="site-main">
      <article class="page">
        <h1>{{ page.title }}</h1>
        {{ content }}
        {% if page.showRecentPosts %}
          <ul>
            {% for post in collections.posts %}
              <li><a href="{{ site.basePath }}{{ post.url }}">{{ post.title }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      </article>
    </main>
    <footer class="site-footer">
      <p>© {{ site.title }}{% if site.description %} — {{ site.description }}{% endif %}</p>
    </footer>
  </body>
</html>

